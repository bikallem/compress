import {
  "bikallem/compress/checksum",
  "bikallem/compress/lzw",
  "moonbitlang/async" @moonasync,
  "moonbitlang/async/fs" @fs,
  "moonbitlang/core/env",
  "moonbitlang/core/strconv",
}

options(
  "is-main": true,
  targets: {
    "main.mbt": [ "native" ],
    "main_wasm.mbt": [ "wasm", "wasm-gc", "js" ],
  },
)
