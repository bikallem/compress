///| Compute the Brotli context ID from two previous bytes and a context mode.
/// mode: 0=LSB6, 1=MSB6, 2=UTF8, 3=SIGNED
fn context_id(p1 : Byte, p2 : Byte, mode : Int) -> Int {
  let base = mode * 512
  brotli_context_lut[base + p1.to_int()].to_int() |
    brotli_context_lut[base + 256 + p2.to_int()].to_int()
}
