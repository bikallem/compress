// Test vectors generated by Go github.com/andybalholm/brotli at quality 1

// empty: 0 -> 1 bytes
let test_empty_compressed : Bytes = [b'\x3B']

// single_a: 1 -> 5 bytes
let test_single_a_compressed : Bytes = [b'\x0B', b'\x00', b'\x80', b'\x61', b'\x03']

// hello: 5 -> 9 bytes
let test_hello_compressed : Bytes = [b'\x0B', b'\x02', b'\x80', b'\x68', b'\x65', b'\x6C', b'\x6C', b'\x6F', b'\x03']

// hello_world: 13 -> 17 bytes
let test_hello_world_compressed : Bytes = [b'\x0B', b'\x06', b'\x80', b'\x48', b'\x65', b'\x6C', b'\x6C', b'\x6F', b'\x2C', b'\x20', b'\x57', b'\x6F', b'\x72', b'\x6C', b'\x64', b'\x21', b'\x03']

// zeros_100: 100 -> 20 bytes
let test_zeros_100_compressed : Bytes = [b'\x8B', b'\x31', b'\x00', b'\x00', b'\x20', b'\x00', b'\xD8', b'\x00', b'\x0E', b'\x5C', b'\xC3', b'\x09', b'\x71', b'\x36', b'\x80', b'\x0B', b'\x70', b'\x58', b'\xDE', b'\x06']

// fox: 450 -> 71 bytes
let test_fox_compressed : Bytes = [b'\x8B', b'\xE0', b'\x00', b'\x00', b'\x80', b'\xAA', b'\xAA', b'\xAA', b'\xEA', b'\xFF', b'\x74', b'\xA5', b'\xC3', b'\x49', b'\x6F', b'\x27', b'\x3D', b'\x5C', b'\x4C', b'\x55', b'\x45', b'\x37', b'\x53', b'\x35', b'\x31', b'\x53', b'\x33', b'\xB5', b'\x0D', b'\x0E', b'\xE0', b'\xE2', b'\x57', b'\x9A', b'\x48', b'\x71', b'\x81', b'\x0D', b'\xC6', b'\x3C', b'\x23', b'\xA8', b'\xB5', b'\x59', b'\x38', b'\x66', b'\xF1', b'\x2B', b'\x6E', b'\xE8', b'\xB3', b'\x11', b'\xF5', b'\xA5', b'\xCE', b'\xBE', b'\x9F', b'\xE8', b'\x2D', b'\x83', b'\x2B', b'\x0B', b'\x6D', b'\xF9', b'\x3F', b'\x82', b'\x26', b'\xC3', b'\x70', b'\x93', b'\x01']

///|
test "decompress empty" {
  let result = decompress!(test_empty_compressed)
  assert_eq!(result.length(), 0)
}

///|
test "decompress single byte" {
  let result = decompress!(test_single_a_compressed)
  assert_eq!(result.length(), 1)
  assert_eq!(result[0], b'\x61') // 'a'
}

///|
test "decompress hello" {
  let result = decompress!(test_hello_compressed)
  assert_eq!(result.length(), 5)
  let expected = b"hello"
  for i in 0..<5 {
    assert_eq!(result[i], expected[i])
  }
}

///|
test "decompress hello world" {
  let result = decompress!(test_hello_world_compressed)
  assert_eq!(result.length(), 13)
  let expected = b"Hello, World!"
  for i in 0..<13 {
    assert_eq!(result[i], expected[i])
  }
}

///|
test "decompress zeros" {
  let result = decompress!(test_zeros_100_compressed)
  assert_eq!(result.length(), 100)
  for i in 0..<100 {
    assert_eq!(result[i], b'\x00')
  }
}

///|
test "decompress fox repeated" {
  let result = decompress!(test_fox_compressed)
  assert_eq!(result.length(), 450)
  let phrase = b"The quick brown fox jumps over the lazy dog. "
  for rep in 0..<10 {
    for i in 0..<45 {
      assert_eq!(result[rep * 45 + i], phrase[i])
    }
  }
}

///|
test "round trip empty" {
  let compressed = compress!(b"", quality=1)
  let result = decompress!(compressed)
  assert_eq!(result.length(), 0)
}

///|
test "round trip hello" {
  let input = b"hello"
  let compressed = compress!(input, quality=1)
  let result = decompress!(compressed)
  assert_eq!(result.length(), input.length())
  for i in 0..<input.length() {
    assert_eq!(result[i], input[i])
  }
}

///|
test "round trip repeated" {
  let input = Bytes::make(1000, b'\x42')
  let compressed = compress!(input, quality=1)
  let result = decompress!(compressed)
  assert_eq!(result.length(), 1000)
  for i in 0..<1000 {
    assert_eq!(result[i], b'\x42')
  }
}

///|
test "streaming decode" {
  // Test streaming: feed compressed data in small chunks
  let inf = Inflater::new()
  let data = test_hello_compressed
  let buf = @buffer.new()
  let mut pos = 0
  loop inf.decode() {
    Await => {
      if pos >= data.length() {
        raise BrotliError::UnexpectedEOF
      }
      // Feed 2 bytes at a time
      let end = if pos + 2 > data.length() { data.length() } else { pos + 2 }
      inf.src(data[pos:end])
      pos = end
      continue inf.decode()
    }
    Data(chunk) => {
      buf.write_bytes(chunk)
      continue inf.decode()
    }
    End => ()
    Error(e) => raise e
  }
  let result = buf.to_bytes()
  assert_eq!(result.length(), 5)
  let expected = b"hello"
  for i in 0..<5 {
    assert_eq!(result[i], expected[i])
  }
}

///|
test "round trip fox" {
  let phrase = b"The quick brown fox jumps over the lazy dog. "
  let input = Bytes::makei(450, fn(i) { phrase[i % 45] })
  let compressed = compress!(input, quality=1)
  let result = decompress!(compressed)
  assert_eq!(result.length(), 450)
  for i in 0..<450 {
    assert_eq!(result[i], input[i])
  }
}

///|
test "round trip quality 0" {
  let input = b"hello world hello world"
  let compressed = compress!(input, quality=0)
  let result = decompress!(compressed)
  assert_eq!(result.length(), input.length())
  for i in 0..<input.length() {
    assert_eq!(result[i], input[i])
  }
}
